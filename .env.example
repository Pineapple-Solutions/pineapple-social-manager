# Pineapple Social Manager v2 — Environment Variables
# ==============================================
# SOLO queste variabili vanno in .env.local
# Le API key di Instagram/OpenAI/Claude/Gemini
# si configurano dalla UI → Provider AI e vengono
# salvate nel database per ogni tenant.
# ==============================================

# --- ffmpeg path (evita problemi di bundling Next.js) ---
FFMPEG_PATH=.\pineapple-social-manager\node_modules\ffmpeg-static\ffmpeg.exe

# --- Database ---
# MySQL (sviluppo locale):
DATABASE_URL="mysql://root:password@localhost:3306/pineapple_social_manager"
# MySQL (produzione / Docker):
# DATABASE_URL="mysql://user:password@db-host:3306/pineapple_social_manager"

# --- Auth Master (non spostare nel DB!) ---
AUTH_SECRET=cambia-questa-stringa-con-una-sicura-in-produzione
MASTER_EMAIL=admin@pineapplehome.it
MASTER_PASSWORD=Admin123!

# --- Timezone ---
TZ=Europe/Rome
